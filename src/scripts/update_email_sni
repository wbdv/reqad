#!/usr/bin/php82
<?php
chdir("/usr/local/reqad/scripts/");
if(php_sapi_name() != "cli" || posix_getuid() != 0) {
    echo "You can only run this script as root from cli.\n";
    exit;
}
if(!is_file(__DIR__.'/../db/reqad.db')) {
	echo "Missing SQLite Database '".__DIR__."'/../db/reqad.db'\n";
	exit;
}

$ini = parse_ini_file(__DIR__.'/../etc/server-software.ini');
if($ini["email"]!="1") {
	echo "Email is disabled in etc/server-software.ini\n";
	foreach(['/etc/exim/sni_certs.db', '/etc/exim/sni_keys.db'] as $f) {
		if(!is_file($f)) file_put_contents($f, "# generated by Reqad\n");
	}
	exit;
}

#$db = new SQLite3(__DIR__.'/../db/reqad.db');
$db = new SQLite3('/usr/local/reqad/db/reqad.db');

// Detect Dovecot version — 2.3 and 2.4 use different SNI cert/key syntax inside
// local_name blocks. 2.3: "ssl_cert = <path" / "ssl_key = <path" (< = read file).
// 2.4: "ssl_server_cert_file = path" / "ssl_server_key_file = path" (no < prefix).
$dovecot_version = trim(shell_exec("dovecot --version 2>/dev/null | awk '{print \$1}'"));
$is_dovecot24 = ($dovecot_version == '') ? true : version_compare($dovecot_version, '2.4', '>=');

$sni_block = function($name, $cert, $key) use ($is_dovecot24) {
	if($is_dovecot24) {
		return "\n".'local_name '.$name.' {
  ssl_server_cert_file = '.$cert.'
  ssl_server_key_file = '.$key.'
}'."\n";
	}
	return "\n".'local_name '.$name.' {
  ssl_cert = <'.$cert.'
  ssl_key = <'.$key.'
}'."\n";
};

$output = shell_exec('sudo cat /etc/exim/userdomains | sort | awk -F\':\' {\'print $1\'}');
$userdomains = explode("\n", trim($output));
#echo '<pre>'; print_r($userdomains); exit;

$sni = "# generated by Reqad\n";

$sni_certs = [];
$sni_keys  = [];

$get_cert_sans = function($cert_file, $key_file) {
	// Fix permissions: cert world-readable, key readable by root+exim only
	shell_exec("chmod a+r ".escapeshellarg($cert_file)." 2>/dev/null");
	shell_exec("chown root:exim ".escapeshellarg($key_file)." 2>/dev/null; chmod 640 ".escapeshellarg($key_file)." 2>/dev/null");
	// Parse SANs from cert (handles multi-domain and wildcard certs)
	$out = shell_exec("openssl x509 -noout -text -in ".escapeshellarg($cert_file)." 2>/dev/null | grep -oP '(?<=DNS:)[^,\s]+'");
	return array_filter(array_map('trim', explode("\n", trim($out))));
};

// Let's Encrypt's cert.pem is the bare leaf (no chain) — SNI needs fullchain.pem
$fix_letsencrypt_chain = function($ssl_cert) {
	if($ssl_cert != '' && strpos($ssl_cert, '/letsencrypt/') !== false && basename($ssl_cert) === 'cert.pem') {
		$fullchain = dirname($ssl_cert).'/fullchain.pem';
		if(is_file($fullchain)) return $fullchain;
	}
	return $ssl_cert;
};

$get_ssl_from_domain = function($d) use ($fix_letsencrypt_chain) {
	// Try nginx (template nginx_php-fpm)
	$ssl_cert = trim(shell_exec('sudo grep ssl_certificate /etc/nginx/conf.d/'.$d.'.conf 2>/dev/null | grep -v ssl_certificate_key | head -n 1 | awk {\'print $2\'} | sed \'s/;//\''));
	if($ssl_cert != '') {
		$ssl_cert_key = trim(shell_exec('sudo grep ssl_certificate_key /etc/nginx/conf.d/'.$d.'.conf 2>/dev/null | head -n 1 | awk {\'print $2\'} | sed \'s/;//\''));
		return [$fix_letsencrypt_chain($ssl_cert), $ssl_cert_key];
	}
	// Try apache (template apache_mod_php)
	$ssl_cert = trim(shell_exec('sudo grep -i "SSLCertificateFile " /etc/httpd/conf.d/'.$d.'.conf 2>/dev/null | head -n 1 | awk {\'print $2\'}'));
	if($ssl_cert != '') {
		$ssl_cert_key = trim(shell_exec('sudo grep -i "SSLCertificateKeyFile " /etc/httpd/conf.d/'.$d.'.conf 2>/dev/null | head -n 1 | awk {\'print $2\'}'));
		return [$fix_letsencrypt_chain($ssl_cert), $ssl_cert_key];
	}
	return ['', ''];
};

$hostname = trim(shell_exec('hostname'));
[$ssl_cert, $ssl_cert_key] = $get_ssl_from_domain($hostname);
if($ssl_cert!='') {
	#echo $hostname."---------\n".$ssl_cert."\n".$ssl_cert_key."\n\n";

	$sni .= $sni_block($hostname, $ssl_cert, $ssl_cert_key);

	foreach($get_cert_sans($ssl_cert, $ssl_cert_key) as $san) {
		$sni_certs[$san] = $ssl_cert;
		$sni_keys[$san]  = $ssl_cert_key;
	}
	if(empty($sni_certs)) {
		$sni_certs[$hostname] = $ssl_cert;
		$sni_keys[$hostname]  = $ssl_cert_key;
	}

	shell_exec("if ! cmp -s $ssl_cert /etc/pki/tls/certs/exim.pem; then cat $ssl_cert > /etc/pki/tls/certs/exim.pem && cat $ssl_cert_key > /etc/pki/tls/private/exim.pem && systemctl restart exim ; fi");
}

$results = $db->query("SELECT * FROM accounts WHERE has_email=1");
while ($row = $results->fetchArray()) {
	if($row["status"]=='active') {
		$d = $row["domain"];
		if(!in_array($d, $userdomains)) {
			echo "Domain $d not found in /etc/exim/userdomains\n";
		} else {
			// check if ssl exists
			[$ssl_cert, $ssl_cert_key] = $get_ssl_from_domain($d);
			if($ssl_cert!='') {
				#echo $d."---------\n".$ssl_cert."\n".$ssl_cert_key."\n\n";
				$sni .= $sni_block('mail.'.$d, $ssl_cert, $ssl_cert_key);
				$sni .= $sni_block($d, $ssl_cert, $ssl_cert_key);

				$sans = $get_cert_sans($ssl_cert, $ssl_cert_key);
				if(!empty($sans)) {
					foreach($sans as $san) {
						$sni_certs[$san] = $ssl_cert;
						$sni_keys[$san]  = $ssl_cert_key;
					}
				} else {
					$sni_certs[$d]         = $ssl_cert;
					$sni_certs['mail.'.$d] = $ssl_cert;
					$sni_keys[$d]          = $ssl_cert_key;
					$sni_keys['mail.'.$d]  = $ssl_cert_key;
				}
			}
		}
	}
}

#echo $sni;

file_put_contents('/etc/dovecot/sni.conf.tmp', $sni);
shell_exec("if ! cmp -s /etc/dovecot/sni.conf.tmp /etc/dovecot/sni.conf; then /bin/mv /etc/dovecot/sni.conf.tmp /etc/dovecot/sni.conf && systemctl restart dovecot; else /bin/rm -f /etc/dovecot/sni.conf.tmp ; fi");

// Generate exim wildlsearch SNI db files
$lsearch_certs = "# generated by Reqad\n";
$lsearch_keys  = "# generated by Reqad\n";
foreach($sni_certs as $domain => $cert) {
	$lsearch_certs .= $domain.': '.$cert."\n";
}
foreach($sni_keys as $domain => $key) {
	$lsearch_keys .= $domain.': '.$key."\n";
}
file_put_contents('/etc/exim/sni_certs.db.tmp', $lsearch_certs);
file_put_contents('/etc/exim/sni_keys.db.tmp',  $lsearch_keys);
shell_exec("if ! cmp -s /etc/exim/sni_certs.db.tmp /etc/exim/sni_certs.db; then /bin/mv /etc/exim/sni_certs.db.tmp /etc/exim/sni_certs.db; else /bin/rm -f /etc/exim/sni_certs.db.tmp; fi");
shell_exec("if ! cmp -s /etc/exim/sni_keys.db.tmp /etc/exim/sni_keys.db; then /bin/mv /etc/exim/sni_keys.db.tmp /etc/exim/sni_keys.db; else /bin/rm -f /etc/exim/sni_keys.db.tmp; fi");
